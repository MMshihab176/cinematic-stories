# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── Admin Auth ──────────────────────────────────────────────────────────────
# The single admin email – must match a confirmed Supabase Auth user
ADMIN_EMAIL=youremail@example.com
# Strong random secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
NEXTAUTH_URL=http://localhost:3000

# ─── Anthropic (AI Chatbot) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=My Story Space

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Max chatbot requests per IP per hour
CHATBOT_RATE_LIMIT=20

# ─── Scheduled Publishing (Vercel Cron) ──────────────────────────────────────
# Generate: openssl rand -base64 32
# Vercel automatically sends this as a Bearer token to cron-triggered routes
# when set as a project environment variable.
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET
